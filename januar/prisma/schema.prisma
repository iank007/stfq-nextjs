generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  class     String   @db.VarChar(10)
  createdAt DateTime @default(now())
}
